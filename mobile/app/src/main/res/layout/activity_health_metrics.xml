<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header back button -->
        <Button
            android:id="@+id/btn_back_to_pets"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back to My Pets"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_health_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Pet's Health Trends"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Segment/Filter Chips Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinner_metric_filter"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_secondary"
                android:backgroundTint="@color/card_bg_surface"
                android:paddingHorizontal="12dp" />
        </LinearLayout>

        <!-- Dynamic form to add metric -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_add_metric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏥 Log Health Update"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Spinner for metric type -->
                <Spinner
                    android:id="@+id/spinner_metric_type"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_secondary"
                    android:backgroundTint="@color/card_bg_surface"
                    android:paddingHorizontal="8dp" />

                <!-- Dynamic inputs container -->
                <LinearLayout
                    android:id="@+id/layout_metric_inputs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <!-- Field 1: Value / Name / Reason -->
                    <EditText
                        android:id="@+id/et_metric_value"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_button_secondary"
                        android:backgroundTint="@color/card_bg_surface"
                        android:hint="Value (e.g. 10.5 kg, Amoxicillin, Vet Visit)"
                        android:inputType="text"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <!-- Field 2: Extra info / Dosage -->
                    <EditText
                        android:id="@+id/et_metric_extra"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_secondary"
                        android:backgroundTint="@color/card_bg_surface"
                        android:hint="Extra Details (e.g. Dosage, vet name)"
                        android:inputType="text"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Date selector -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/et_metric_date"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:backgroundTint="@color/card_bg_surface"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:hint="Date (yyyy-mm-dd)"
                        android:inputType="none"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btn_pick_metric_date"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_gradient_primary"
                        android:contentDescription="Select Date"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="@color/white" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_save_metric"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_gradient_primary"
                    android:text="Save Health Log"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- RecyclerView list of entries -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_metrics"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            tools:listitem="@layout/item_activity" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

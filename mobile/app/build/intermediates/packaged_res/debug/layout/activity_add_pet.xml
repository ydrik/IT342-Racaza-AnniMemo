<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Header Navigation row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_back_to_pets"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back to My Pets"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_form_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Add New Pet"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Create a profile for your companion to start tracking their care."
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

        <!-- Error / Success banner -->
        <TextView
            android:id="@+id/tv_form_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/error_bg"
            android:padding="12dp"
            android:textColor="@color/error"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Form Card Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 1. Pet Name Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pet Name *"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_pet_name"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:backgroundTint="@color/card_bg_surface"
                    android:hint="e.g. Max"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <!-- 2. Species Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Species *"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_species"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:backgroundTint="@color/card_bg_surface"
                    android:paddingHorizontal="12dp" />

                <!-- 3. Breed Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Breed"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_pet_breed"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:backgroundTint="@color/card_bg_surface"
                    android:hint="e.g. Golden Retriever"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <!-- 4. Gender Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Gender"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_gender"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:backgroundTint="@color/card_bg_surface"
                    android:paddingHorizontal="12dp" />

                <!-- 5. Date of Birth Field (with icon picker, disable manual keyboard inputs) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Date of Birth"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/et_pet_dob"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:backgroundTint="@color/card_bg_surface"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:hint="mm/dd/yyyy"
                        android:inputType="none"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btn_pick_date"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_gradient_primary"
                        android:contentDescription="Select Date"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="@color/white" />
                </LinearLayout>

                <!-- 6. Weight Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Weight (kg)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_pet_weight"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:backgroundTint="@color/card_bg_surface"
                    android:hint="e.g. 12.5"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <!-- 7. Color Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Color"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_pet_color"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:backgroundTint="@color/card_bg_surface"
                    android:hint="e.g. Golden, Brown"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <!-- 8. Notes Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Notes"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_pet_notes"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:backgroundTint="@color/card_bg_surface"
                    android:gravity="top|start"
                    android:hint="Special diets, medical history, notes..."
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <!-- Save Button -->
                <Button
                    android:id="@+id/btn_save_pet"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_gradient_primary"
                    android:text="Save Pet Profile"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
